local function switchTab(id)
    if currentTabId and tabs[currentTabId] then tabs[currentTabId].content = textBox.Text end
    currentTabId = id
    textBox.Text = tabs[id].content
    for i, v in pairs(tabs) do
        v.btn.BackgroundColor3 = (i == id and Color3.fromRGB(35, 35, 35) or Color3.fromRGB(20, 20, 20))
        v.btn.UIStroke.Color = (i == id and accentColor or Color3.fromRGB(50, 50, 50))
    end
end

local function createTab()
    local id = tostring(tick())
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 30)
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    btn.Text = "  Script " .. (#tabList:GetChildren() - 1)
    btn.TextColor3, btn.ZIndex = Color3.fromRGB(255, 255, 255), 12
    btn.Font, btn.TextSize, btn.TextXAlignment = Enum.Font.Gotham, 11, Enum.TextXAlignment.Left
    btn.Parent = tabList
    addCorner(btn, 6)
    addStroke(btn, Color3.fromRGB(50, 50, 50), 1)
    tabs[id] = {btn = btn, content = ""}
    btn.MouseButton1Click:Connect(function() switchTab(id) end)
    switchTab(id)
end

