local function addToTerminal(msg, color)
    local log = Instance.new("TextLabel")
    log.Size = UDim2.new(1, -10, 0, 16)
    log.BackgroundTransparency = 1
    log.Text = " [>] " .. tostring(msg)
    log.TextColor3 = color or Color3.fromRGB(150, 150, 150)
    log.Font, log.TextSize, log.ZIndex = Enum.Font.Code, 11, 12
    log.TextXAlignment = Enum.TextXAlignment.Left
    log.Parent = terminalFrame
    terminalFrame.CanvasSize = UDim2.new(0, 0, 0, termLayout.AbsoluteContentSize.Y)
    terminalFrame.CanvasPosition = Vector2.new(0, 9999)
end

